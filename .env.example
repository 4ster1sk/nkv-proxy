# ============================================================
# Misskey-Mastodon Proxy 設定ファイル
# cp .env.example .env して編集してください
# ============================================================

# ──────────────────────────────────────
# 必須: Misskey インスタンス
# ──────────────────────────────────────
MISSKEY_INSTANCE_URL=https://misskey.io

# ──────────────────────────────────────
# アプリ設定
# ──────────────────────────────────────
APP_NAME=Misskey-Mastodon-Proxy

# このプロキシ自身の公開 URL（外部からアクセス可能な URL）
# miAuth コールバック・nodeinfo href に使用
# 例: https://proxy.example.com
PROXY_BASE_URL=

# OAuth コールバック URL（空 = OOB モード）
APP_CALLBACK_URL=

# ──────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────
POSTGRES_USER=proxy
POSTGRES_PASSWORD=proxy_secret_change_me
POSTGRES_DB=miauth_proxy

# miAuth セッション有効期限（秒）
MIAUTH_SESSION_TTL=600

# ──────────────────────────────────────
# サーバー設定
# ──────────────────────────────────────
LISTEN_PORT=8000

# uvicorn ワーカー数（Streaming 利用時は 1 推奨）
WORKERS=1
