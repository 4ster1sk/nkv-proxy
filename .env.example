# ============================================================
# Misskey-Mastodon Proxy 設定ファイル
# cp .env.example .env して値を編集してください
# ============================================================

# ──────────────────────────────────────
# 必須設定
# ──────────────────────────────────────

# このプロキシ自身の公開 URL（必須推奨）
# Mastodon OAuth コールバックや NodeInfo の生成に使用される
# 未設定の場合はリクエストの Host ヘッダーから自動推定する
PROXY_BASE_URL=https://your-proxy.example.com

# 上流 Mastodon インスタンスのデフォルト URL
# ユーザーがダッシュボードで個別に Mastodon 連携を設定した場合はそちらが優先される
# ここで指定するのは未設定ユーザーへのフォールバック
MASTODON_INSTANCE_URL=https://nekonoverse.org

# ──────────────────────────────────────
# データベース設定
# ──────────────────────────────────────

# PostgreSQL 接続 DSN
DATABASE_URL=postgresql+asyncpg://proxy:proxy@postgres:5432/proxy_db

# ──────────────────────────────────────
# アプリ設定
# ──────────────────────────────────────

# miAuth 認証画面・NodeInfo 等に表示されるアプリ名
APP_NAME=Misskey-Mastodon-Proxy

# インスタンス表示名（/api/v1/instance に返す）
INSTANCE_TITLE=Misskey-Mastodon Bridge
INSTANCE_DESCRIPTION=Misskey client compatible proxy for Mastodon

# ──────────────────────────────────────
# セッション設定
# ──────────────────────────────────────

# miAuth セッション有効期限（秒）
MIAUTH_SESSION_TTL=600

# Mastodon OAuth state 有効期限（秒）
MASTODON_OAUTH_STATE_TTL=300

# ──────────────────────────────────────
# サーバー設定
# ──────────────────────────────────────

# ホストマシンで公開するポート番号
LISTEN_PORT=8000

# uvicorn ワーカー数
# WebSocket/SSE ストリーミングを使う場合は 1 を推奨
WORKERS=1

# LTL (Local Timeline) 制御
# auto:  上流インスタンスの /api/v2/instance を確認して自動判定（TTL 3時間キャッシュ）
# true:  強制有効
# false: 強制無効（デフォルト動作と同じ）
ENABLE_LOCAL_TIMELINE=auto

# ──────────────────────────────────────
# デバッグ設定
# ──────────────────────────────────────

# ログレベル（デフォルト: INFO）
# DEBUG / INFO / WARNING / ERROR のいずれかを指定
#LOG_LEVEL=DEBUG

# ストリーミングデバッグログ（デフォルト: false）
# true にすると SSE の生ライン・変換前後のデータを DEBUG レベルで出力する
# LOG_LEVEL=DEBUG かつ STREAMING_DEBUG=true の両方が必要
#STREAMING_DEBUG=true
