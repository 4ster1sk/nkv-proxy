# ============================================================
# Misskey-Mastodon Proxy — docker-compose
#
# 使い方:
#   cp .env.example .env    # .env を編集してから
#   docker compose up -d
# ============================================================

services:

  # ─── PostgreSQL ───────────────────────────────────────────
  postgres:
    image: postgres:16-alpine
    container_name: misskey-mastodon-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: "${POSTGRES_USER:-proxy}"
      POSTGRES_PASSWORD: "${POSTGRES_PASSWORD:-proxy}"
      POSTGRES_DB: "${POSTGRES_DB:-miauth_proxy}"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-proxy} -d ${POSTGRES_DB:-miauth_proxy}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    logging:
      driver: "json-file"
      options:
        max-size: "5m"
        max-file: "3"
  # ─── メインプロキシ ───────────────────────────────────────
  proxy:
    build:
      context: .
      dockerfile: Dockerfile
      target: runtime          # マルチステージの runtime ステージ
    image: misskey-mastodon-proxy:latest
    container_name: misskey-mastodon-proxy
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy

    ports:
      - "${LISTEN_PORT:-8000}:8000"

    environment:
      MISSKEY_INSTANCE_URL: "${MISSKEY_INSTANCE_URL:-https://misskey.io}"
      APP_NAME: "${APP_NAME:-Misskey-Mastodon-Proxy}"
      APP_CALLBACK_URL: "${APP_CALLBACK_URL:-}"
      PROXY_BASE_URL: "${PROXY_BASE_URL:-}"
      WORKERS: "${WORKERS:-1}"
      # PostgreSQL DSN (asyncpg)
      DATABASE_URL: "postgresql+asyncpg://${POSTGRES_USER:-proxy}:${POSTGRES_PASSWORD:-proxy}@postgres:5432/${POSTGRES_DB:-miauth_proxy}"
      MIAUTH_SESSION_TTL: "${MIAUTH_SESSION_TTL:-600}"

    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/api/v1/streaming/health"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 5s
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "5"
    deploy:
      resources:
        limits:
          memory: 256M
        reservations:
          memory: 64M


  # ─── リバースプロキシ (Nginx) ─────────────────────────────
  # HTTPS 終端・WebSocket プロキシが必要な場合に使用
  # 不要な場合は profiles: [nginx] のまま起動しなければ OK
  nginx:
    image: nginx:1.27-alpine
    container_name: misskey-mastodon-nginx
    restart: unless-stopped
    #profiles:
    #  - nginx                  # docker compose --profile nginx up で有効化
    ports:
      - "80:80"
      - "443:443"
    depends_on:
      proxy:
        condition: service_healthy
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./nginx/certs:/etc/nginx/certs:ro     # TLS証明書を配置
    #depends_on:
    #  proxy:
    #    condition: service_healthy
    logging:
      driver: "json-file"
      options:
        max-size: "5m"
        max-file: "3"

volumes:
  postgres_data: